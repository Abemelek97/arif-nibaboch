<div class="space-y-3">
  <% poll.poll_options.includes(:poll_votes).each do |option| %>
    <% user_voted = current_user.present? && option.poll_votes.any? { |vote| vote.user_id == current_user.id } %>
    <div
      class="
        flex items-center justify-between p-4 rounded-lg border border-border
        bg-background
      "
    >
      <div class="flex items-center gap-3">
        <span class="font-bold text-content"><%= option.content %></span>
        <% if user_voted %>
          <span class="text-[10px] font-semibold uppercase tracking-wide text-primary bg-primary/10 border border-primary/20 rounded-full px-2 py-0.5">
            Your vote
          </span>
        <% end %>
      </div>
      <span class="text-xs font-semibold text-content-muted">
        <%= pluralize(option.poll_votes.size, "vote") %>
      </span>
    </div>
  <% end %>
</div>
