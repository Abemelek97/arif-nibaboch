<%= form_with url: book_club_book_read_poll_votes_path(book_club, book_read),
  method: :post,
  data: { controller: "poll-vote-form" },
  id: "poll_vote_form",
  class: "space-y-3" do %>
  <% poll.poll_options.includes(:poll_votes).each do |option| %>
    <label
      class="
        flex items-center justify-between p-4 rounded-lg border border-border
        bg-background hover:bg-surface transition-all group
      "
    >
      <div class="flex items-start gap-3">
        <%= check_box_tag "poll_option_ids[]",
        option.id,
        false,
        class: "mt-0.5",
        data: { poll_vote_form_target: "option", action: "poll-vote-form#toggle" } %>
        <span class="font-bold text-content"><%= option.content %></span>
      </div>
    </label>
  <% end %>

  <button
    type="submit"
    data-poll-vote-form-target="submit"
    disabled
    class="
      px-5 py-2 rounded-md text-xs font-bold transition-colors shadow-sm
      text-primary-contrast bg-primary hover:bg-primary
      focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary
      disabled:opacity-50 disabled:cursor-not-allowed
    "
  >
    Vote
  </button>
<% end %>
