<div id="<%= dom_id(discussion_question) %>" class="p-5 bg-surface rounded-2xl border border-border shadow-sm hover:shadow-md transition-shadow flex items-start gap-5 relative overflow-hidden group">
  <div class="flex flex-col items-center gap-2 w-20 flex-shrink-0">
    <% if discussion_question.user.present? %>
      <%= render "shared/avatar", user: discussion_question.user, classes: "w-11 h-11 ring-2 ring-surface bg-primary text-primary-contrast text-sm font-semibold" %>
      <span class="text-xs font-semibold text-content w-full text-center truncate"><%= discussion_question.user.name.presence || discussion_question.user.username.presence || discussion_question.user.email.split("@").first %></span>
    <% else %>
      <div class="w-11 h-11 rounded-full bg-background flex items-center justify-center text-xs font-semibold text-content-subtle border border-border">
        A
      </div>
      <span class="text-xs font-semibold text-content-subtle w-full text-center truncate">Anonymous</span>
    <% end %>
  </div>

  <div class="flex-grow">
    <div class="flex items-center gap-3 mb-2">
      <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-background text-content border border-border">
        #<%= discussion_question.position %>
      </span>
    </div>
    <p class="text-content text-base sm:text-lg font-medium leading-relaxed"><%= discussion_question.content_for_language(user_device_language) %></p>
    
    <% if discussion_question.draft? %>
      <div class="mt-3 flex items-center gap-2">
        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-background text-content border border-border">
          <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
          </svg>
          Draft
        </span>
        
        <% if user_signed_in? && current_user == discussion_question.book_read.book_club.owner %>
          <%= button_to book_club_book_read_discussion_question_path(discussion_question.book_read.book_club, discussion_question.book_read, discussion_question), method: :patch, params: { discussion_question: { status: :approved } }, class: "inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-background text-primary border border-primary hover:bg-background transition-colors cursor-pointer" do %>
            Approve
          <% end %>
        <% end %>
      </div>
    <% elsif discussion_question.approved? %>
      <div class="mt-3 flex items-center gap-2">
        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-background text-primary border border-border">
          <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
             <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
          Approved
        </span>
        
        <% if user_signed_in? && current_user == discussion_question.book_read.book_club.owner %>
          <%= button_to book_club_book_read_discussion_question_path(discussion_question.book_read.book_club, discussion_question.book_read, discussion_question, discussion_question: { status: :revealed }), method: :patch, class: "inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-background text-primary border border-primary hover:bg-background transition-colors cursor-pointer" do %>
            Reveal Live
          <% end %>
        <% end %>
      </div>
    <% elsif discussion_question.revealed? %>
      <div class="mt-3 flex items-center gap-2">
        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-background text-primary border border-border">
          <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          Revealed
        </span>
      </div>
    <% end %>
  </div>
</div>
